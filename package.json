{
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "biome check . && prettier --check 'src/**/*.{astro,mdx}' && astro check",
    "format": "biome check --write . && prettier --write 'src/**/*.{astro,mdx}'",
    "lint": "biome lint ."
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.3",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "^2.5.4",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "typescript": "^6.0.3"
  }
}
