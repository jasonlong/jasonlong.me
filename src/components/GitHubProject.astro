---
const { name, description, repo } = Astro.props

let starCount: number | null = null

const headers: Record<string, string> = { 'User-Agent': 'jasonlong.me' }
if (process.env.GITHUB_TOKEN) {
  headers['Authorization'] = `Bearer ${process.env.GITHUB_TOKEN}`
}

try {
  const response = await fetch(`https://api.github.com/repos/${repo}`, {
    headers,
  })
  if (response.ok) {
    const data = await response.json()
    starCount = data.stargazers_count
  }
} catch {
  // Fetch failed, show without stars
}
---

<a href=`https://github.com/${repo}`>{name}</a>: {description}{starCount && ` (⭑${new Intl.NumberFormat().format(starCount)})`}
